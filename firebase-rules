rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 🟢 This rule applies ONLY to documents inside the 'demo' collection
    match /demo/{document} {
      // Allow read access to EVERYONE (public access)
      allow read: if true;

      // Keep write access restricted to only signed-in users
      allow write: if request.auth != null;
    }

    match /authorization-logs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /risk-assessments/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /funds-released-logs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /captured-logs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 🔒 All other collections are still restricted by default
  }
}